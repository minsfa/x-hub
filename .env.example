# API URL (ngrok 사용 시: https://xxxx.ngrok-free.app/api)
VITE_API_URL=

# Database (PostgreSQL)
DATABASE_URL="postgresql://xhub:xhub_secret@localhost:5432/xhub?schema=public"

# PostgreSQL (for docker-compose)
POSTGRES_USER=xhub
POSTGRES_PASSWORD=xhub_secret
POSTGRES_DB=xhub

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=xhub-reports

# JWT (인증)
JWT_SECRET=your-secret-key-change-in-production
